# Optional: Hugging Face token for gated models or higher rate limits
# HF_TOKEN=

# Suppress Transformers weight-load reports and progress noise (benchmark / ML backends)
TRANSFORMERS_VERBOSITY=error

# Runtime profile (backend, model, threshold, labels). Default: ./config/ner.yaml
# NER_CONFIG_PATH=./config/ner.yaml

# LLM backend (OpenRouter). Use provider: mock in benchmark YAML for offline runs.
# OPENROUTER_API_KEY=   # required for llm-nemotron-ultra benchmark run
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# MOCK_LLM=false        # when true, openrouter provider uses mock client
